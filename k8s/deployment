apiVersion: apps/v1
kind: Deployment
metadata:
  name: mail-deployment
spec:
  replicas: 2
  selector:
    matchLabels:
      app: satya
  template:
    metadata:
      labels:
        app: satya
    spec:
      containers:
      - name: mail-cont
        image: sunithriyansh/email:latest
        ports:
        - containerPort: 80
